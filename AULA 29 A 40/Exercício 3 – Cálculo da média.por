programa
{
    funcao inicio()
    {
        real n1, n2, media

        escreva("Digite o primeiro numero: ") //inclusao de codigo para melhoria de usabilidade
        leia(n1)

        escreva("Digite o segundo numero: ") //inclusao de codigo para melhoria de usabilidade
        leia(n2)

        //media = (n1 + n2) / 3
        media = (n1 + n2) / 2

        escreva("Média: ", media)
    }
}