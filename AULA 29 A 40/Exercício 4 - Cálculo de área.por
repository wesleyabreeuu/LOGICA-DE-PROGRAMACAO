programa
{
    funcao inicio()
    {
        //inteiro largura, altura
        real largura, altura
        real area


        escreva("Digite a largura: ") //código para melhoria de usabilidade
        leia(largura)

        escreva("Digite a altura: ") //código para melhoria de usabilidade
        leia(altura)

        area = largura * altura

        escreva("Área: ", area)
    }
}