programa
{
    funcao inicio()
    {
        inteiro idade

        escreva("Digite sua idade: ") //codigo para melhoria de usabilidade
        leia(idade)

       // se (idade >= 12 ou idade <= 17)
        se (idade >= 12 e idade <= 17)
        {
            escreva("Adolescente")
        }
        senao
        {
            escreva("Não é adolescente")
        }
    }
}