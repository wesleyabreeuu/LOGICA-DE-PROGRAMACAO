programa {
  funcao inicio() {
    cadeia produto
    inteiro quant
    real preco
    logico disp

    produto = "notebook"
    quant = 5
    preco = 1000
    disp = verdadeiro

    escreva("Na loja do sr. João, o ", produto, " custa apenas ", preco, " reais. ", "\n",
    "É verdade que tem ", quant, " disponiveis? ", disp)
    
  }
}
