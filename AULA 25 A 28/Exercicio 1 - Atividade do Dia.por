programa {
  funcao inicio() {
    inteiro idade = 20

    escreva("A idade é maior ou igual a 18 anos? ", idade >= 18, "\n")
    escreva("A idade é menor que 18 anos? ", idade < 18, "\n")
    escreva("A idade é igual a 20 anos? ", idade == 20, "\n")
    escreva("A idade é diferente de 15 anos? ", idade != 15, "\n")
  }
}
