programa {
  funcao inicio() {
    inteiro a = 10
    inteiro b = 25

    escreva("A variavel a é maior que b? ", a > b, "\n")
    escreva("A variavel a é menor que b? ", a < b, "\n")
    escreva("A variavel a é igual a b? ", a == b, "\n")
    escreva("A variavel b é maior ou igual a 25? ", b >= 25, "\n")
  }
}
