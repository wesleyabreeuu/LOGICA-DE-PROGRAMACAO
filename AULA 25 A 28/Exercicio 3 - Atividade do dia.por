programa {
  funcao inicio() {
    real nota

    escreva("Digite a sua nota: ")
    leia(nota)

    escreva("A nota é maior ou igual a 7? ", nota >= 7, "\n")
    escreva("A nota é menor que 5? ", nota < 5, "\n")
    escreva("A nota é igual a 10? ", nota == 10, "\n")
    escreva("A nota é menor ou igual a 6? ", nota <= 6, "\n")
  }
}
